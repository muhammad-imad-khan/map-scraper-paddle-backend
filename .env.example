# ==================================================================
# Runtime mode switch
# If true: backend uses *_PRODUCTION variables.
# If false: backend uses *_DEVELOPMENT variables.
# ==================================================================
IS_PRODUCTION=false

# ==================================================================
# Paddle credentials (mode-aware)
# ==================================================================
PADDLE_API_KEY_PRODUCTION=
PADDLE_API_KEY_DEVELOPMENT=

PADDLE_WEBHOOK_SECRET_PRODUCTION=
PADDLE_WEBHOOK_SECRET_DEVELOPMENT=

# Optional override (usually auto-derived by IS_PRODUCTION)
# Valid values: production|live|sandbox
PADDLE_ENV_PRODUCTION=production
PADDLE_ENV_DEVELOPMENT=sandbox

# ==================================================================
# Redis (mode-aware)
# ==================================================================
REDIS_URL_PRODUCTION=
REDIS_URL_DEVELOPMENT=redis://localhost:6379

# ==================================================================
# Price IDs (mode-aware)
# ==================================================================
PRICE_PRO_PRODUCTION=
PRICE_PRO_DEVELOPMENT=

PRICE_ENTERPRISE_PRODUCTION=
PRICE_ENTERPRISE_DEVELOPMENT=

PRICE_ONE_TIME_ID_PRODUCTION=
PRICE_ONE_TIME_ID_DEVELOPMENT=

PRICE_ONE_TIME_INTL_ID_PRODUCTION=
PRICE_ONE_TIME_INTL_ID_DEVELOPMENT=

PRICE_COURSE_ID_PRODUCTION=
PRICE_COURSE_ID_DEVELOPMENT=

PRICE_COURSE_INTL_ID_PRODUCTION=
PRICE_COURSE_INTL_ID_DEVELOPMENT=

# Optional additional tool checkout price. Leave blank unless this is another
# tool or lifetime Paddle price ID. Never point this at a course price.
PRICE_CHECKOUT_FALLBACK_ID_PRODUCTION=
PRICE_CHECKOUT_FALLBACK_ID_DEVELOPMENT=

# ==================================================================
# URLs (mode-aware)
# ==================================================================
FRONTEND_URL_PRODUCTION=https://map-scrapper-five.vercel.app
FRONTEND_URL_DEVELOPMENT=http://localhost:5500

SITE_ORIGIN_PRODUCTION=https://map-scrapper-five.vercel.app
SITE_ORIGIN_DEVELOPMENT=http://localhost:5500

CUSTOMER_PORTAL_URL_PRODUCTION=https://map-scrapper-five.vercel.app/portal/
CUSTOMER_PORTAL_URL_DEVELOPMENT=http://localhost:5500/portal/

# ==================================================================
# Course + admin (mode-aware where needed)
# ==================================================================
DEFAULT_COURSE_ID_PRODUCTION=lead-gen-ai-web-design
DEFAULT_COURSE_ID_DEVELOPMENT=lead-gen-ai-web-design

COURSE_LINK_PRODUCTION=
COURSE_LINK_DEVELOPMENT=

ADMIN_EMAIL_PRODUCTION=
ADMIN_EMAIL_DEVELOPMENT=

# Admin API key for secure access to /api/admin-users
ADMIN_API_KEY=

# ==================================================================
# Google service account (shared)
# ==================================================================
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# ==================================================================
# SMTP (shared)
# ==================================================================
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=
SMTP_TLS_REJECT_UNAUTHORIZED=
SMTP_FROM=

# Optional transactional email provider for course delivery.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Imad Khan Courses <courses@yourdomain.com>

PORT=3000
