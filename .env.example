# ── Paddle Sandbox Keys ──────────────────────────────────
# Get these from: https://sandbox-vendors.paddle.com/authentication
PADDLE_API_KEY=your_sandbox_api_key_here
PADDLE_WEBHOOK_SECRET=your_sandbox_webhook_secret_here

# Paddle environment: "sandbox" or "live"
PADDLE_ENV=sandbox

# Admin API key for secure access to /api/admin-users
ADMIN_API_KEY=replace_with_a_long_random_secret

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Paddle Price IDs (from Paddle Catalog > Products > Prices) ──
PRICE_STARTER=pri_your_starter_price_id
PRICE_PRO=pri_your_pro_price_id
PRICE_ENTERPRISE=pri_your_enterprise_price_id
PRICE_ONE_TIME_ID=pri_your_one_time_price_id
PRICE_ONE_TIME_LABEL=$5.99
PRICE_ONE_TIME_INTL_ID=pri_your_one_time_intl_price_id
PRICE_ONE_TIME_INTL_LABEL=$20
PRICE_COURSE_ID=pri_your_course_price_id

# ── Course Delivery (Google Drive link emailed after purchase) ──
COURSE_LINK=https://drive.google.com/drive/folders/your-folder-id

# ── Google Service Account (for Drive folder sharing) ────
# Option A: paste the entire JSON key file content
GOOGLE_SERVICE_ACCOUNT_JSON=
# Option B: individual fields
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# ── Email Notifications (Gmail SMTP) ─────────────────────
# Create a Gmail App Password: Google Account → Security → App Passwords
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
ADMIN_EMAIL=your_email@gmail.com

# ── URLs ─────────────────────────────────────────────────
SITE_ORIGIN=https://mapsleadscraper.com
PORT=3000
