{
  "version": 2,
  "framework": null,
  "buildCommand": "",
  "outputDirectory": "",
  "functions": {
    "api/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Accept, X-Install-Id, X-Client-Id, X-Admin-Key, Authorization" }
      ]
    }
  ]
}
